# Dar Tahara environment configuration
# Copy to .env.local. Never expose server secrets with NEXT_PUBLIC_ names.

NODE_ENV=production
APP_BASE_URL=https://dartahara.com
LOG_LEVEL=info

NEXT_PUBLIC_SITE_URL=https://dartahara.com

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Private operations portal
ADMIN_API_TOKEN=
ADMIN_SESSION_SECRET=

# Stripe — merchant of record: Paradox FZCO (Dubai, UAE).
# Use test keys (sk_test_… / pk_test_…) in dev & staging, live keys only in prod.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard → Billing → Customer portal → save configuration → copy id (bpc_…)
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=
# Checkout/settlement currency (centralised; default eur).
STRIPE_DEFAULT_CURRENCY=eur
# Stripe account country (Paradox FZCO → AE).
STRIPE_ACCOUNT_COUNTRY=AE
# Up to 22 chars shown on the customer's bank statement.
STRIPE_STATEMENT_DESCRIPTOR=DAR TAHARA
# Set to "true" to enable Stripe Tax automatic calculation (requires Tax setup).
STRIPE_TAX_ENABLED=false

# Email
RESEND_API_KEY=
MAILING_FROM_EMAIL=Dar Tahara <hello@dartahara.com>

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_API_VERSION=v25.0
# Independent high-entropy secrets used for AES-GCM storage and HMAC lookups.
WHATSAPP_DATA_ENCRYPTION_KEY=
WHATSAPP_PHONE_HASH_SECRET=
WHATSAPP_JOB_SECRET=
WHATSAPP_MESSAGE_RETENTION_DAYS=90
WHATSAPP_AUDIT_RETENTION_DAYS=365
WHATSAPP_RATE_LIMIT_PER_MINUTE=12
WHATSAPP_MAX_MESSAGE_LENGTH=3000
WHATSAPP_MAX_CONTEXT_MESSAGES=12
# Backwards-compatible aliases; prefer META_APP_SECRET / WHATSAPP_API_VERSION.
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=
WHATSAPP_TEMPLATE_BOOKING_CONFIRMED=
WHATSAPP_TEMPLATE_APPOINTMENT_REMINDER=
WHATSAPP_TEMPLATE_REVISED_QUOTE=
WHATSAPP_TEMPLATE_SUBSCRIPTION_ACTIVATED=
WHATSAPP_TEMPLATE_PAYMENT_CONFIRMED=
WHATSAPP_TEMPLATE_ASSESSMENT_COMPLETED=
WHATSAPP_TEMPLATE_FAILED_PAYMENT=
WHATSAPP_TEMPLATE_HUMAN_FOLLOWUP=
WHATSAPP_TEMPLATE_ANNUAL_RENEWAL=

# Shared assistant / AI provider abstraction
# Leave unset to use the deterministic grounded-answer fallback only.
ASSISTANT_PROVIDER=
ASSISTANT_API_BASE_URL=
ASSISTANT_API_KEY=
ASSISTANT_MODEL=
ASSISTANT_FALLBACK_MODEL=
ASSISTANT_TIMEOUT_MS=8000
ASSISTANT_MAX_TOKENS=450
ASSISTANT_TEMPERATURE=0.2
ASSISTANT_RETRIEVAL_LIMIT=4
ASSISTANT_CONFIDENCE_THRESHOLD=0.62

# Groq (preferred AI provider; deterministic knowledge fallback remains active on failure)
GROQ_API_KEY=
GROQ_MODEL=
GROQ_TIMEOUT_MS=15000
GROQ_MAX_TOKENS=600

# FreeScout API is preferred. If unavailable, configure the support mailbox and
# Resend values for idempotent email ingestion.
FREESCOUT_BASE_URL=
FREESCOUT_API_KEY=
FREESCOUT_MAILBOX_ID=
FREESCOUT_SUPPORT_EMAIL=
FREESCOUT_FROM_EMAIL=
FREESCOUT_DEFAULT_ASSIGNEE_ID=
FREESCOUT_DEFAULT_TAGS=

# Optional Cloudflare Turnstile protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics 4 (Consent Mode v2 — only loads after visitor accepts).
# Analytics → Admin → Data Streams → your web stream → Measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Mautic (marketing backend) ─────────────────────────────────────────────────
# Server-side API access for contact sync. Credentials are the dedicated dt-api
# user (NOT the admin) — see deploy/mautic. Never expose these to the browser.
MAUTIC_BASE_URL=https://marketing.saasolution.es
MAUTIC_API_USERNAME=dt-api
MAUTIC_API_PASSWORD=
MAUTIC_API_TIMEOUT_MS=10000

# Public tracking script (mtc.js). Consent-gated: only loads after the visitor
# accepts analytics. Set ENABLED=true to switch it on in an environment.
NEXT_PUBLIC_MAUTIC_BASE_URL=https://marketing.saasolution.es
NEXT_PUBLIC_MAUTIC_TRACKING_ENABLED=false

# ── Early-access verification / anti-spam ──────────────────────────────────────
# Salt for hashing IPs in consent metadata and for verification-token flows.
EMAIL_VERIFICATION_SIGNING_SECRET=
RATE_LIMIT_SECRET=
