# Mautic deployment — environment contract.
#
# The real .env lives ONLY on the VPS at /opt/projects/mautic/.env, owned by
# root with mode 0600, and is generated by ./bootstrap.sh. Nothing in this file
# is a real secret; it documents the variables and their shape.
#
# Regenerating secrets: rotating MAUTIC_DB_PASSWORD requires also updating the
# MariaDB user (see README §Rotating secrets). Rotating MAUTIC_SECRET_KEY
# invalidates existing sessions and remember-me cookies but loses no data.

# ── Image ──────────────────────────────────────────────────────────────────────
# Pinned to an exact patch release, never `latest`: an unattended `docker compose
# pull` must not silently move Mautic across a major version and run migrations.
MAUTIC_IMAGE_TAG=7.1.3-apache

# ── Database (MariaDB, internal network only) ──────────────────────────────────
MAUTIC_DB_DATABASE=mautic
MAUTIC_DB_USER=mautic
MAUTIC_DB_PASSWORD=generate-with-bootstrap.sh
MAUTIC_DB_ROOT_PASSWORD=generate-with-bootstrap.sh

# ── Application ────────────────────────────────────────────────────────────────
# Must be the public HTTPS URL: Mautic bakes it into tracking pixels, form
# actions and every link in an outbound email. Getting it wrong sends customers
# to a dead host.
MAUTIC_SITE_URL=https://marketing.saasolution.es
# Symfony secret — signs sessions/CSRF tokens. 32+ random bytes, hex.
MAUTIC_SECRET_KEY=generate-with-bootstrap.sh

# ── Mail transport ─────────────────────────────────────────────────────────────
# Resend SMTP, sending as Dar Tahara. The API key is a Resend key (re_...) and
# `resend` is the literal SMTP username Resend expects.
#   smtp://resend:<RESEND_API_KEY>@smtp.resend.com:587
# dartahara.com must be a verified domain in Resend with its DKIM records
# published, or mail will be rejected at submission time.
MAUTIC_MAILER_DSN=smtp://resend:re_your_key_here@smtp.resend.com:587
MAUTIC_MAILER_FROM_NAME=Dar Tahara
MAUTIC_MAILER_FROM_EMAIL=hello@dartahara.com
